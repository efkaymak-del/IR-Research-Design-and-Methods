/* ===== APP ENGINE ===== */

var currentTab = "epistemology";
var currentTradFilter = "all";

function el(id) { return document.getElementById(id); }

function showTab(id) {
  currentTab = id;
  var tabs = document.querySelectorAll(".tab");
  for (var i = 0; i < tabs.length; i++) { tabs[i].className = "tab"; }
  var btns = document.querySelectorAll("nav button");
  for (var i = 0; i < btns.length; i++) { btns[i].className = ""; }
  var t = el("tab-" + id);
  if (t) { t.className = "tab show"; }
  var b = el("btn-" + id);
  if (b) { b.className = "active"; }
  if (id === "readings") { renderReadings(); }
}

function toggleCard(elem) {
  if (elem.classList.contains("open")) {
    elem.classList.remove("open");
  } else {
    elem.classList.add("open");
  }
}

function buildNav() {
  var nav = el("topnav");
  var html = "";
  for (var i = 0; i < TABS.length; i++) {
    html += '<button id="btn-' + TABS[i].id + '" onclick="showTab(\'' + TABS[i].id + '\')">' + TABS[i].label + '</button>';
  }
  nav.innerHTML = html;
}

function buildApp() {
  var app = el("app");
  var html = "";
  for (var i = 0; i < TABS.length; i++) {
    html += '<div class="tab" id="tab-' + TABS[i].id + '">';
    html += getTabContent(TABS[i].id);
    html += '</div>';
  }
  app.innerHTML = html;
  buildNav();
  showTab("epistemology");
}

function getTabContent(id) {
  if (id === "epistemology") return tabEpistemology();
  if (id === "alignment") return tabAlignment();
  if (id === "cases") return tabCases();
  if (id === "nsize") return tabNsize();
  if (id === "methods") return tabMethods();
  if (id === "builder") return tabBuilder();
  if (id === "checker") return tabChecker();
  if (id === "readings") return tabReadings();
  return "";
}

