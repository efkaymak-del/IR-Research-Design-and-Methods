<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',system-ui,sans-serif;background:#f5f6fa;color:#1e293b;line-height:1.6}
header{background:linear-gradient(135deg,#1e3a5f,#2563eb);color:#fff;padding:20px;text-align:center}
header h1{font-size:1.5em}
header p{font-size:.85em;opacity:.85;margin-top:4px}
nav{display:flex;flex-wrap:wrap;gap:6px;padding:12px;background:#fff;border-bottom:1px solid #e2e8f0;justify-content:center;position:sticky;top:0;z-index:100}
nav button{padding:7px 13px;border:1px solid #cbd5e1;border-radius:20px;background:#f8fafc;color:#334155;font-size:.78em;cursor:pointer;transition:.2s;white-space:nowrap}
nav button:hover{background:#e0e7ff;border-color:#818cf8}
nav button.active{background:#2563eb;color:#fff;border-color:#2563eb}
.tab{display:none;padding:16px;max-width:900px;margin:0 auto}
.tab.show{display:block}
.card{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:18px;margin-bottom:14px;cursor:pointer;transition:.2s;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.card:hover{box-shadow:0 4px 12px rgba(0,0,0,.1);border-color:#93c5fd}
.card h3{font-size:1.05em;color:#1e3a5f;display:flex;justify-content:space-between;align-items:center}
.card h3::after{content:'\25B8';transition:.2s;font-size:.9em;color:#94a3b8}
.card.open h3::after{transform:rotate(90deg);color:#2563eb}
.card-body{display:none;margin-top:12px;padding-top:12px;border-top:1px solid #f1f5f9;font-size:.92em;color:#475569}
.card.open .card-body{display:block}
.tag{display:inline-block;padding:3px 10px;border-radius:12px;font-size:.75em;font-weight:600;margin:2px}
.tag-pos{background:#dbeafe;color:#1e40af}
.tag-int{background:#fef3c7;color:#92400e}
.tag-crit{background:#fce7f3;color:#9d174d}
.tag-method{background:#d1fae5;color:#065f46}
.tag-mixed{background:#e0e7ff;color:#3730a3}
.stitle{font-size:1.15em;font-weight:700;color:#1e3a5f;margin:18px 0 10px;padding-bottom:6px;border-bottom:2px solid #2563eb}
.matrix{width:100%;border-collapse:collapse;font-size:.85em;margin:12px 0}
.matrix th,.matrix td{padding:10px;border:1px solid #e2e8f0;text-align:left}
.matrix th{background:#f0f4ff;color:#1e3a5f;font-weight:600}
.matrix tr:nth-child(even){background:#f8fafc}
.ibox{background:#eff6ff;border-left:4px solid #2563eb;padding:14px;border-radius:0 8px 8px 0;margin:12px 0;font-size:.9em;color:#1e40af}
.wbox{background:#fef3c7;border-left:4px solid #f59e0b;padding:14px;border-radius:0 8px 8px 0;margin:12px 0;font-size:.9em;color:#92400e}
.ref{font-size:.82em;color:#64748b;font-style:italic;margin-top:6px}
.fg{margin-bottom:14px}
.fg label{display:block;font-weight:600;color:#1e3a5f;margin-bottom:4px;font-size:.9em}
.fg input,.fg textarea,.fg select{width:100%;padding:10px;border:1px solid #cbd5e1;border-radius:8px;font-size:.9em;font-family:inherit;background:#fff}
.fg textarea{min-height:70px;resize:vertical}
.btn{padding:10px 22px;border:none;border-radius:8px;font-size:.9em;cursor:pointer;font-weight:600;transition:.2s;margin:4px}
.btn-p{background:#2563eb;color:#fff}.btn-p:hover{background:#1d4ed8}
.btn-s{background:#e2e8f0;color:#334155}.btn-s:hover{background:#cbd5e1}
.btn-g{background:#059669;color:#fff}.btn-g:hover{background:#047857}
.obox{background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:18px;margin-top:14px;white-space:pre-wrap;font-size:.88em;line-height:1.7;color:#334155;display:none}
.obox.show{display:block}
.exmp{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:12px;margin:8px 0;font-size:.88em}
.cr{padding:14px;border-radius:8px;margin:10px 0;font-size:.9em}
.cr-pass{background:#d1fae5;border:1px solid #6ee7b7;color:#065f46}
.cr-warn{background:#fef3c7;border:1px solid #fcd34d;color:#92400e}
.cr-fail{background:#fee2e2;border:1px solid #fca5a5;color:#991b1b}
.srch{width:100%;padding:10px;border:1px solid #cbd5e1;border-radius:8px;font-size:.9em;margin-bottom:14px}
.rcard{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:14px;margin-bottom:10px}
.rcard h4{color:#1e3a5f;font-size:.95em;margin-bottom:4px}
.rcard p{font-size:.84em;color:#475569;margin-bottom:4px}
.tsel{display:flex;gap:8px;margin:12px 0;flex-wrap:wrap}
.tbtn{padding:10px 18px;border:2px solid #e2e8f0;border-radius:10px;cursor:pointer;font-weight:600;font-size:.88em;transition:.2s;background:#fff}
.tbtn:hover{border-color:#2563eb}
.tbtn.sel{border-color:#2563eb;background:#eff6ff;color:#2563eb}
@media(max-width:600px){nav{gap:4px;padding:8px}nav button{font-size:.72em;padding:6px 10px}}
</style>
</head>
