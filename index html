function runChecker() {
  var epist = el("ck-epist").value;
  var theory = el("ck-theory").value;
  var method = el("ck-method").value;
  var n = el("ck-n").value;
  var rq = (el("ck-rq").value || "").trim();
  if (!epist || !theory || !method) { alert("Please fill in epistemology, theory, and method."); return; }

  var results = [];
  var posT = ["realism","liberalism","rational"];
  var intT = ["constructivism","english","practice"];
  var critT = ["marxism","feminism","postcolonial","poststructural","green"];
  var posM = ["statistical","formal","comparison","qca","process","content","mixed_method"];
  var intM = ["discourse","ethnography","narrative","process","content","historical"];
  var critM = ["discourse","genealogy","feminist_method","ethnography","narrative","historical"];

  // Epistemology-Theory
  if (epist === "Positivist" && critT.indexOf(theory) >= 0) {
    results.push({t:"warn", m:"EPISTEMOLOGY - THEORY TENSION: You selected a positivist epistemology with a critical theory. Critical theories typically reject value-neutral inquiry. This can work if you operationalise the theory in a testable way, but be explicit about the tension."});
  } else if (epist === "Critical" && posT.indexOf(theory) >= 0) {
    results.push({t:"warn", m:"EPISTEMOLOGY - THEORY TENSION: You selected a critical epistemology with a mainstream/positivist theory. Consider whether you are critiquing the theory itself or applying a critical lens to its assumptions."});
  } else if (epist === "Interpretivist" && theory === "rational") {
    results.push({t:"warn", m:"EPISTEMOLOGY - THEORY TENSION: Rational choice theory assumes utility-maximising agents and is typically embedded in positivist epistemology. If you are studying how rational-choice discourses are deployed, that could work - but clarify your analytical move."});
  } else {
    results.push({t:"pass", m:"EPISTEMOLOGY - THEORY: Your epistemological stance and theoretical tradition appear coherent."});
  }

  // Epistemology-Method
  var mOk = false;
  if (epist === "Positivist" && posM.indexOf(method) >= 0) mOk = true;
  if (epist === "Interpretivist" && intM.indexOf(method) >= 0) mOk = true;
  if (epist === "Critical" && critM.indexOf(method) >= 0) mOk = true;
  if (epist === "Mixed") mOk = true;
  if (!mOk) {
    var sug = "";
    if (epist === "Positivist") sug = "Consider: statistical analysis, formal modelling, structured comparison, process tracing, or QCA.";
    if (epist === "Interpretivist") sug = "Consider: discourse analysis, ethnography, interpretive process tracing, narrative analysis, or comparative historical analysis.";
    if (epist === "Critical") sug = "Consider: critical discourse analysis, genealogy, feminist methodology, or reflexive ethnography.";
    results.push({t:"warn", m:"EPISTEMOLOGY - METHOD TENSION: The method you chose is not typically associated with your epistemological stance. You will need to explicitly justify the combination. " + sug});
  } else {
    results.push({t:"pass", m:"EPISTEMOLOGY - METHOD: Your method is well-suited to your epistemological tradition."});
  }

  // N-size
  if (n === "large" && ["discourse","ethnography","genealogy","feminist_method","narrative"].indexOf(method) >= 0) {
    results.push({t:"warn", m:"N-SIZE - METHOD TENSION: You selected a large-N design with a method that typically works with small-N or single cases. Large-N variants exist (e.g., automated text analysis) but require a different approach. Be specific."});
  } else if (n === "1" && ["statistical","formal","qca"].indexOf(method) >= 0) {
    results.push({t:"fail", m:"N-SIZE - METHOD MISMATCH: Statistical analysis, formal modelling, and QCA require multiple cases. A single case study cannot support these methods. Consider process tracing or within-case analysis instead."});
  } else if (n === "medium" && method === "qca") {
    results.push({t:"pass", m:"N-SIZE - METHOD: Medium-N is the sweet spot for QCA. Good alignment."});
  } else if (n) {
    results.push({t:"pass", m:"N-SIZE - METHOD: Your case count and method appear compatible."});
  }

  // RQ keywords
  if (rq) {
    var rqL = rq.toLowerCase();
    if (epist === "Positivist" && (rqL.indexOf("how do actors understand") >= 0 || rqL.indexOf("what meanings") >= 0)) {
      results.push({t:"warn", m:"QUESTION - EPISTEMOLOGY NOTE: Your research question uses interpretivist language but you selected a positivist epistemology. Positivist questions typically ask about causes, effects, and conditions. Revisit either the question or the epistemological choice."});
    }
    if (epist === "Interpretivist" && (rqL.indexOf("cause") >= 0 || rqL.indexOf("what is the effect") >= 0)) {
      results.push({t:"warn", m:"QUESTION - EPISTEMOLOGY NOTE: Your research question uses causal language but you selected an interpretivist epistemology. Interpretivists typically ask about meaning, constitution, and practice. Consider rephrasing or reconsidering your stance."});
    }
  }

  // Render
  var container = el("ck-results");
  var html = '<div class="stitle" style="margin-top:16px">Diagnostic Results</div>';
  var allPass = true;
  for (var i = 0; i < results.length; i++) {
    var r = results[i];
    var cls = r.t === "pass" ? "cr-pass" : (r.t === "warn" ? "cr-warn" : "cr-fail");
    var icon = r.t === "pass" ? "PASS" : (r.t === "warn" ? "WARNING" : "MISMATCH");
    if (r.t !== "pass") allPass = false;
    html += '<div class="cr ' + cls + '"><b>' + icon + ':</b> ' + r.m + '</div>';
  }
  if (allPass) {
    html += '<div class="cr cr-pass" style="margin-top:10px"><b>Overall:</b> Your research design elements appear well-aligned. Proceed with confidence - but always discuss coherence with your supervisor.</div>';
  } else {
    html += '<div class="ibox" style="margin-top:10px"><b>Next steps:</b> Review the flagged tensions. Alignment issues are common and fixable - the point is to be explicit about your choices. Discuss with your supervisor and consult the Reading Navigator tab.</div>';
  }
  container.innerHTML = html;
}

function clearChecker() {
  var ids = ["ck-rq","ck-epist","ck-theory","ck-method","ck-n"];
  for (var i = 0; i < ids.length; i++) {
    var e = el(ids[i]);
    if (e.tagName === "SELECT") e.selectedIndex = 0;
    else e.value = "";
  }
  el("ck-results").innerHTML = "";
}

/* ----- TAB 8: READINGS ----- */
function tabReadings() {
  var h = '<div class="stitle">Reading Navigator</div>';
  h += '<div class="ibox">A curated library of foundational methods texts and exemplary IR works. Use search and filters below.</div>';
  h += '<input type="text" class="srch" id="readSearch" placeholder="Search by title, author, or keyword..." oninput="renderReadings()">';
  h += '<div style="margin-bottom:12px">';
  var filters = ["All","Positivist","Interpretivist","Critical","Mixed","General"];
  for (var i = 0; i < filters.length; i++) {
    h += '<button class="btn btn-s" style="font-size:.8em" onclick="currentTradFilter=\'' + filters[i] + '\';renderReadings()">' + filters[i] + '</button> ';
  }
  h += '</div>';
  h += '<div id="readList"></div>';
  return h;
}

function renderReadings() {
  var search = (el("readSearch") ? el("readSearch").value : "").toLowerCase();
  var container = el("readList");
  if (!container) return;
  var filtered = [];
  for (var i = 0; i < READINGS.length; i++) {
    var r = READINGS[i];
    if (currentTradFilter !== "All" && currentTradFilter !== "all" && r.tradition !== currentTradFilter) continue;
    if (search && (r.title + " " + r.author + " " + r.desc + " " + r.tradition + " " + r.type).toLowerCase().indexOf(search) < 0) continue;
    filtered.push(r);
  }
  if (filtered.length === 0) {
    container.innerHTML = '<p style="color:#94a3b8;padding:20px;text-align:center">No readings match your search.</p>';
    return;
  }
  var html = "";
  for (var i = 0; i < filtered.length; i++) {
    var r = filtered[i];
    var tcls = "";
    if (r.tradition === "Positivist") tcls = "tag-pos";
    else if (r.tradition === "Interpretivist") tcls = "tag-int";
    else if (r.tradition === "Critical") tcls = "tag-crit";
    else if (r.tradition === "Mixed") tcls = "tag-mixed";
    html += '<div class="rcard">';
    html += '<h4>' + r.title + ' (' + r.year + ')</h4>';
    html += '<p><b>' + r.author + '</b></p>';
    html += '<p>' + r.desc + '</p>';
    html += '<span class="tag ' + tcls + '">' + r.tradition + '</span> <span class="tag tag-method">' + r.type + '</span>';
    html += '</div>';
  }
  container.innerHTML = html;
}

/* ===== START ===== */
buildApp();
