<script>
/* ========== TAB DEFINITIONS ========== */
const TABS=[
{id:'epistemology',label:'Epistemological Compass'},
{id:'alignment',label:'Theory–Method Alignment'},
{id:'cases',label:'Case Selection'},
{id:'nsize',label:'N-Size Guide'},
