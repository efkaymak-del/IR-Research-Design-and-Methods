/* ========== DATA ========== */

const TRADITIONS=[
{name:'Positivism',tag:'tag-pos',color:'#2563eb',
 ontology:'An objective, observable social reality exists independently of the researcher. Patterns and regularities can be discovered.',
 epistemology:'Knowledge is gained through empirical observation, measurement, and hypothesis testing. Causal inference is the goal.',
 goal:'To explain, predict, and generalise. Seeks law-like regularities and causal mechanisms.',
 scholars:'King, Keohane & Verba (KKV); Waltz; Mearsheimer; Fearon; Lake; Bueno de Mesquita',
 methods:'Statistical analysis, formal modelling, large-N studies, structured-focused comparison, process tracing (theory-testing variant)',
 works:[
  {title:'Designing Social Inquiry',author:'King, Keohane & Verba (1994)',note:'The foundational text linking qualitative and quantitative research through a unified logic of inference. Argues all good research approximates the experimental ideal.'},
  {title:'War and the Changing Global Order',author:'Rasler & Thompson (1989)',note:'Large-N study of war, hegemonic transition, and systemic change using quantitative longitudinal data.'},
  {title:'Rationalist Explanations for War',author:'Fearon (1995)',note:'Formal-theoretic analysis of bargaining failures. Demonstrates how rational choice models generate testable hypotheses in security studies.'},
  {title:'The Tragedy of Great Power Politics',author:'Mearsheimer (2001)',note:'Offensive realism derived deductively with historical case testing. A model of positivist theory-building in IR.'}
 ]},
{name:'Interpretivism',tag:'tag-int',color:'#d97706',
 ontology:'Social reality is constructed through meaning, language, and intersubjective understanding. There is no single objective reality in politics.',
 epistemology:'Knowledge is gained through understanding (Verstehen), interpretation of meaning, and contextual analysis. The researcher is embedded in the inquiry.',
 goal:'To understand, interpret, and reconstruct the meanings that actors bring to their social and political worlds.',
 scholars:'Wendt; Kratochwil; Onuf; Pouliot; Adler; Fierke; Hopf; Schwartz-Shea & Yanow',
 methods:'Discourse analysis, ethnography, narrative analysis, practice theory, interpretive process tracing, participant observation',
 works:[
  {title:'Anarchy is What States Make of It',author:'Wendt (1992)',note:'Foundational constructivist argument that the international system's character depends on shared ideas, not material distribution alone.'},
  {title:'International Practices',author:'Adler & Pouliot, eds. (2011)',note:'Practice-turn in IR. Shows how diplomacy, deterrence, and alliance management are constituted through habitual social practices.'},
  {title:'Interpretation and Method',author:'Schwartz-Shea & Yanow (2012)',note:'Comprehensive guide to interpretive research design. Essential reading for qualitative IR scholars working outside the KKV paradigm.'},
  {title:'Diplomatic Investigations',author:'Butterfield & Wight (1966)',note:'English School classic demonstrating how interpretive historical analysis illuminates international society.'}
 ]},
{name:'Critical Theory',tag:'tag-crit',color:'#be185d',
 ontology:'Social reality is shaped by power, ideology, and historical structures of domination. What appears "natural" is often socially constructed to serve particular interests.',
 epistemology:'Knowledge is never neutral — it is always produced within power structures. The purpose of inquiry is emancipation and the exposure of hidden power relations.',
 goal:'To critique, unmask, and transform. Research should reveal how existing arrangements serve dominant interests and imagine alternatives.',
 scholars:'Cox; Linklater; Booth; Enloe; Tickner; Acharya; Hobson; Said; Spivak; Ackerly & True',
 methods:'Critical discourse analysis, genealogy, postcolonial analysis, feminist methodology, historical-structural analysis, reflexive ethnography',
 works:[
  {title:'Social Forces, States and World Orders',author:'Cox (1981)',note:'"Theory is always for someone and for some purpose." The defining statement of critical IR theory, distinguishing problem-solving from critical theory.'},
  {title:'Bananas, Beaches and Bases',author:'Enloe (1990)',note:'Feminist IR classic showing how gender structures international politics in ways mainstream theories ignore.'},
  {title:'The Eurocentrism of IR',author:'Hobson (2012)',note:'Systematic critique of how IR theory has been built on Eurocentric assumptions, marginalising non-Western agency.'},
  {title:'Doing Feminist Research in Political and Social Science',author:'Ackerly & True (2010)',note:'Practical guide to feminist research ethics and methodology. Shows how normative commitments shape research design choices.'}
 ]}
];

const CASE_TYPES=[
{name:'Most Similar Systems Design (MSSD)',
 aka:'Mill\'s Method of Difference',
 logic:'Select cases that are as similar as possible on all variables except the outcome and the hypothesised cause. Differences in outcome can then be attributed to the differing variable.',
 example:'Skocpol\'s <em>States and Social Revolutions</em> (1979) compares France, Russia, and China — states with broadly similar agrarian-bureaucratic structures that experienced revolution — to isolate causes.',
 when:'When you want to control for confounding variables by holding context constant.',
 ref:'Przeworski & Teune (1970); Lijphart (1971)'},
{name:'Most Different Systems Design (MDSD)',
 aka:'Mill\'s Method of Agreement',
 logic:'Select cases that differ on as many variables as possible but share the same outcome. If the outcome is present across very different contexts, the common factor is likely causal.',
 example:'Collier & Collier\'s <em>Shaping the Political Arena</em> (1991) examines eight Latin American countries with very different characteristics that all experienced critical junctures in labour incorporation.',
 when:'When you want to show that a finding is robust across diverse contexts.',
 ref:'Przeworski & Teune (1970); Anckar (2008)'},
{name:'Crucial Case',
 aka:'Least-Likely / Most-Likely',
 logic:'A most-likely case is one where conditions are most favourable for a theory; if it fails there, the theory is seriously weakened. A least-likely case is the opposite: if the theory holds even under unfavourable conditions, it is strongly supported.',
 example:'Eckstein (1975) proposed the logic. George & Bennett (2005) refine it. Pape\'s (2005) study of suicide terrorism as a least-likely case for strategic rationality.',
 when:'When you want to strongly test a theory with a single or small number of cases.',
 ref:'Eckstein (1975); Levy (2008); George & Bennett (2005)'},
{name:'Deviant Case',
 aka:'Anomalous / Outlier Case',
 logic:'Select a case that deviates from the prediction of an established theory. Analysis focuses on why the case is anomalous and what it reveals about the theory\'s scope conditions.',
 example:'Katzenstein\'s <em>The Culture of National Security</em> (1996) examines cases where realist predictions about threat response fail, revealing the role of identity and culture.',
 when:'When an existing theory cannot explain an important case and you want to refine or challenge that theory.',
 ref:'Gerring (2007); Seawright & Gerring (2008)'},
{name:'Pathway Case',
 aka:'Causal Mechanism Case',
 logic:'Select cases specifically to trace the causal mechanisms linking a cause to an outcome. The goal is not to test whether X causes Y, but how.',
 example:'Tannenwald\'s <em>The Nuclear Taboo</em> (2007) traces the causal mechanisms by which a norm against nuclear use emerged and was sustained across multiple decision points.',
 when:'When the causal relationship is established but the mechanism is unclear or contested.',
 ref:'George & Bennett (2005); Beach & Pedersen (2013)'},
{name:'Typological Case Selection',
 aka:'Typological Theory',
 logic:'Develop a typology of theoretically relevant case types (based on combinations of key variables) and select cases from each cell to test how different combinations produce different outcomes.',
 example:'Elman\'s typological theory of democratic peace examines different combinations of regime type, threat level, and alliance structure.',
 when:'When multiple causal paths exist and you want to map the full landscape of possibilities.',
 ref:'George & Bennett (2005), Ch. 11; Elman (2005)'}
];

const NSIZE=[
{type:'Large-N (Quantitative)',n:'Typically 30+ cases, often hundreds or thousands',
 strengths:'Generalisability, statistical control for confounders, identification of broad patterns, replicability.',
 limits:'Risks conceptual stretching; may miss context; causal mechanisms remain a black box; data availability and quality issues in IR.',
 methods:'Regression analysis, time-series analysis, panel data, event data, survival analysis, formal modelling.',
 key_refs:'King, Keohane & Verba (1994); Russett (1993); Oneal & Russett (1999); Bueno de Mesquita et al. (2003)',
 ir_example:'Russett\'s <em>Grasping the Democratic Peace</em> (1993) uses statistical analysis of all dyads to test whether democracies fight each other less.'},
{type:'Small-N Comparative (2–10 cases)',n:'Typically 2–10 cases',
 strengths:'Combines breadth with depth; structured comparison allows controlled analysis; balances generalisability and contextual sensitivity.',
 limits:'Cannot fully control for all confounders; case selection is critical and can introduce bias; results less generalisable than large-N.',
 methods:'Structured-focused comparison, QCA (Qualitative Comparative Analysis), comparative process tracing, MSSD/MDSD.',
 key_refs:'George & Bennett (2005); Ragin (1987/2008); Slater & Ziblatt (2013); Mahoney & Rueschemeyer (2003)',
 ir_example:'George & Smoke\'s <em>Deterrence in American Foreign Policy</em> (1974) uses structured-focused comparison of multiple deterrence cases.'},
{type:'Single Case Study (N=1)',n:'One case, studied intensively',
 strengths:'Maximum depth; rich causal-mechanism tracing; can uncover processes invisible to large-N; ideal for theory-building or crucial-case testing.',
 limits:'Cannot generalise statistically; external validity depends on case selection rationale; risks over-determination.',
 methods:'Process tracing, congruence testing, counterfactual analysis, within-case analysis, archival research, elite interviews.',
 key_refs:'Van Evera (1997); Bennett & Checkel (2015); Beach & Pedersen (2013); Gerring (2007)',
 ir_example:'Allison\'s <em>Essence of Decision</em> (1971) applies three theoretical lenses to the Cuban Missile Crisis — the canonical single-case study in IR.'},
{type:'Mixed Methods',n:'Combines large-N and small-N/single-case',
 strengths:'Triangulation; large-N identifies patterns, case studies trace mechanisms; compensates for weaknesses of each approach alone.',
 limits:'Requires competence in multiple methods; more resource-intensive; integration of findings can be challenging.',
 methods:'Nested analysis (large-N + within-case), sequential designs, multi-method research.',
 key_refs:'Lieberman (2005); Seawright (2016); Goertz & Mahoney (2012); Humphreys & Jacobs (2015)',
 ir_example:'Lieberman\'s nested analysis framework: run a regression, identify interesting cases from the residuals, then process-trace those cases.'}
];

const METHODS_LIB=[
{name:'Process Tracing',tradition:'Positivist / Interpretivist',
 desc:'A within-case method that examines the causal chain linking a cause to an outcome. The researcher looks for observable manifestations (causal-process observations) of each link in the theorised mechanism.',
 when:'When you need to establish "how" and "why" a causal relationship works, not just "whether."',
 variants:'Theory-testing process tracing, theory-building process tracing, explaining-outcome process tracing (Beach & Pedersen 2013).',
 exemplar:{title:'The Nuclear Taboo',author:'Tannenwald (2007)',note:'Traces the causal mechanism by which a normative prohibition against nuclear weapons use developed and was sustained across Cold War crises.'},
 readings:'Bennett & Checkel, eds. (2015) <em>Process Tracing</em>; Beach & Pedersen (2013) <em>Process-Tracing Methods</em>; George & Bennett (2005), Ch. 10; Van Evera (1997), Ch. 2.',
 tags:['tag-pos','tag-int']},
{name:'Discourse Analysis',tradition:'Interpretivist / Critical',
 desc:'Examines how language, texts, and communication construct social realities, identities, and power relations. Focuses on what is said, how it is said, what is silenced, and what subject positions are made available.',
 when:'When your research question concerns how meaning is produced, how identities are constructed, or how power operates through language.',
 variants:'Foucauldian discourse analysis, critical discourse analysis (Fairclough), poststructuralist discourse theory (Laclau & Mouffe), narrative analysis.',
 exemplar:{title:'National Identity and the Varieties of Capitalism',author:'Schmidt (2002)',note:'Uses discursive institutionalism to show how different national discourses about economic policy shape reform trajectories.'},
 readings:'Milliken (1999) in <em>European Journal of International Relations</em>; Hansen (2006) <em>Security as Practice</em>; Fairclough (2003) <em>Analysing Discourse</em>.',
 tags:['tag-int','tag-crit']},
{name:'Qualitative Comparative Analysis (QCA)',tradition:'Positivist / Mixed',
 desc:'A set-theoretic method that uses Boolean algebra to identify which combinations of conditions are necessary or sufficient for an outcome. Bridges qualitative depth with systematic comparison.',
 when:'When you have a medium-N (10–50 cases), expect equifinality (multiple paths to the same outcome), and want to identify necessary/sufficient conditions.',
 variants:'Crisp-set QCA (csQCA), fuzzy-set QCA (fsQCA), multi-value QCA (mvQCA).',
 exemplar:{title:'Fuzzy-Set Social Science',author:'Ragin (2000)',note:'Introduces fsQCA methodology. Applied widely in comparative politics and IR for analysing complex causation.'},
 readings:'Ragin (2008) <em>Redesigning Social Inquiry</em>; Schneider & Wagemann (2012) <em>Set-Theoretic Methods</em>; Thiem & Duşa (2013).',
 tags:['tag-pos','tag-mixed']},
{name:'Statistical Analysis',tradition:'Positivist',
 desc:'Uses mathematical models to identify patterns, correlations, and causal effects across many observations. Central to the large-N tradition in IR.',
 when:'When you want to test hypotheses across a broad population of cases, control for alternative explanations, and establish generalisable findings.',
 variants:'OLS regression, logistic regression, panel data models, time-series cross-section (TSCS), instrumental variables, difference-in-differences, survival/hazard models.',
 exemplar:{title:'Triangulating Peace',author:'Russett & Oneal (2001)',note:'Statistical analysis of the Kantian peace thesis — democracy, trade, and international organisations all reduce conflict.'},
 readings:'King, Keohane & Verba (1994); Wooldridge (2020) <em>Introductory Econometrics</em>; Kellstedt & Whitten (2018) <em>The Fundamentals of Political Science Research</em>.',
 tags:['tag-pos']},
{name:'Ethnography & Participant Observation',tradition:'Interpretivist / Critical',
 desc:'Involves extended immersion in a social setting to understand practices, meanings, and power relations from the inside. The researcher participates in and observes the community being studied.',
 when:'When your question concerns how practices are lived, how meaning is made in everyday interactions, or how institutions actually function on the ground.',
 variants:'Political ethnography, institutional ethnography, auto-ethnography, micro-sociology of international practice.',
 exemplar:{title:'Peaceland',author:'Séverine Autesserre (2014)',note:'Ethnographic study of international peacebuilding practitioners in the DRC and Timor-Leste, revealing how everyday practices undermine peacebuilding goals.'},
 readings:'Schatz, ed. (2009) <em>Political Ethnography</em>; Wedeen (2010) in <em>Annual Review of Political Science</em>; Pouliot (2010).',
 tags:['tag-int','tag-crit']},
{name:'Content Analysis',tradition:'Positivist / Interpretivist',
 desc:'Systematic coding and analysis of texts, speeches, media, or other communicative material. Can be quantitative (counting frequencies) or qualitative (interpreting themes and frames).',
 when:'When you need to analyse large volumes of textual or media data systematically, or when you want to map how a concept is framed across sources.',
 variants:'Quantitative content analysis, qualitative content analysis (Mayring), automated text analysis, frame analysis.',
 exemplar:{title:'Framing Terrorism',author:'Entman (2004)',note:'Systematic analysis of how US media framed terrorism events, demonstrating the power of framing in shaping public opinion and policy.'},
 readings:'Krippendorff (2018) <em>Content Analysis</em>; Neuendorf (2017); Schreier (2012) <em>Qualitative Content Analysis in Practice</em>.',
 tags:['tag-pos','tag-int']},
{name:'Comparative Historical Analysis',tradition:'Positivist / Interpretivist / Critical',
 desc:'Examines historical sequences, critical junctures, and long-term processes across cases to explain macro-level political outcomes. Combines narrative depth with systematic comparison.',
 when:'When your question concerns large-scale, long-term political outcomes (state formation, regime change, war) and the historical processes that produced them.',
 variants:'Path dependence analysis, critical juncture analysis, periodic comparison, historical institutionalism.',
 exemplar:{title:'States and Social Revolutions',author:'Skocpol (1979)',note:'Compares France, Russia, and China to explain why social revolutions occurred. The paradigmatic work in comparative historical analysis.'},
 readings:'Mahoney & Rueschemeyer, eds. (2003) <em>Comparative Historical Analysis in the Social Sciences</em>; Mahoney & Thelen (2010); Pierson (2004) <em>Politics in Time</em>.',
 tags:['tag-pos','tag-int','tag-crit']}
];

const READINGS=[
{title:'Designing Social Inquiry',author:'King, Keohane & Verba',year:1994,type:'Methods Text',tradition:'Positivist',desc:'The foundational text on causal inference in qualitative research. Argues for a unified logic of inference across methods. Essential but contested.'},
{title:'Writing a Research Paper in Political Science',author:'Baglione, Lisa',year:2020,type:'Methods Text',tradition:'General',desc:'Practical step-by-step guide to research design, argument construction, and writing. Ideal for MA and early-PhD students. Fourth edition covers digital resources.'},
{title:'Case Studies and Theory Development in the Social Sciences',author:'George & Bennett',year:2005,type:'Methods Text',tradition:'General',desc:'The key text on case study methods in IR. Covers process tracing, typological theory, structured-focused comparison, and case selection.'},
{title:'Guide to Methods for Students of Political Science',author:'Van Evera, Stephen',year:1997,type:'Methods Text',tradition:'Positivist',desc:'Concise, practical guide to hypothesis testing, case selection, and process tracing. A go-to for security studies students.'},
