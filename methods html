/* Tradition selector in Tab 2 */
function initTradSelector(){
  const sel=document.getElementById('tradSel');
  if(!sel) return;
  sel.innerHTML='';
  const data=[
    {label:'Positivist',cls:'tag-pos',detail:`
      <strong>Positivist Pathway:</strong><br>
      <strong>Start with:</strong> an observable puzzle → <strong>Derive:</strong> a testable hypothesis from theory (deductive) → <strong>Choose:</strong> method that allows causal inference (statistical analysis, structured comparison, process tracing) → <strong>Select cases:</strong> based on variation in key variables (MSSD, crucial case) → <strong>Evaluate:</strong> using empirical evidence and counterfactuals.<br><br>
      <strong>The KKV Standard:</strong> Maximise observable implications of your hypothesis. Avoid selection on the dependent variable. Seek leverage through controlled comparison. Report uncertainty honestly.<br><br>
      <div class="ref">Key texts: King, Keohane & Verba (1994); Van Evera (1997); Kellstedt & Whitten (2018).</div>
    `},
    {label:'Interpretivist',cls:'tag-int',detail:`
      <strong>Interpretivist Pathway:</strong><br>
      <strong>Start with:</strong> a puzzling social practice, contested meaning, or identity formation → <strong>Approach with:</strong> openness to how actors construct their world (abductive/inductive) → <strong>Choose:</strong> method that uncovers meaning (discourse analysis, ethnography, interpretive process tracing) → <strong>Select cases:</strong> based on richness of meaning-making, not statistical representativeness → <strong>Evaluate:</strong> through trustworthiness, reflexivity, thick description, inter-subjective plausibility.<br><br>
      <strong>Beyond KKV:</strong> Schwartz-Shea & Yanow (2012) argue that interpretive research has its own standards of rigour — not less rigorous than positivism, but differently rigorous.<br><br>
      <div class="ref">Key texts: Schwartz-Shea & Yanow (2012); Pouliot (2010); Wedeen (2002).</div>
    `},
    {label:'Critical',cls:'tag-crit',detail:`
      <strong>Critical Pathway:</strong><br>
      <strong>Start with:</strong> a situation of injustice, domination, or silencing → <strong>Ask:</strong> who benefits from the current arrangement and whose voices are excluded? → <strong>Choose:</strong> method that reveals power structures (critical discourse analysis, genealogy, feminist methodology) → <strong>Engage reflexively:</strong> acknowledge your own positionality and normative commitments → <strong>Aim for:</strong> not just description or explanation, but transformation and emancipation.<br><br>
      <strong>Cox's Dictum:</strong> All theory serves someone's interests. Critical research makes this explicit and asks whose interests are served by existing knowledge structures.<br><br>
      <div class="ref">Key texts: Cox (1981); Ackerly & True (2010); Enloe (1990); Hobson (2012).</div>
    `}
  ];
  data.forEach(d=>{
    const b=document.createElement('div');
    b.className='tradition-btn';
    b.innerHTML=`<span class="tag ${d.cls}">${d.label}</span>`;
    b.onclick=function(){
      document.querySelectorAll('.tradition-btn').forEach(x=>x.classList.remove('sel'));
      this.classList.add('sel');
      document.getElementById('tradDetail').innerHTML=`<div class="info-box" style="margin-top:12px">${d.detail}</div>`;
    };
    sel.appendChild(b);
  });
}

/* Builder generate */
function generateDesign(){
  const g=id=>document.getElementById(id).value.trim();
  const title=g('bd-title'),puzzle=g('bd-puzzle'),rq=g('bd-rq'),epist=g('bd-epist'),
        theory=g('bd-theory'),hyp=g('bd-hyp'),method=g('bd-method'),
        cases=g('bd-cases'),data=g('bd-data'),contrib=g('bd-contrib'),refs=g('bd-refs');
  if(!rq){alert('Please enter at least a research question.');return;}
  const out=document.getElementById('bd-output');
  out.innerHTML=
`<strong>═══════════════════════════════════════════</strong>
<strong>RESEARCH DESIGN MEMO</strong>
<strong>═══════════════════════════════════════════</strong>

<strong>Project:</strong> ${title||'[Untitled]'}

<strong>1. RESEARCH PUZZLE</strong>
${puzzle||'[Not specified]'}

<strong>2. RESEARCH QUESTION</strong>
${rq}

<strong>3. EPISTEMOLOGICAL TRADITION</strong>
${epist||'[Not specified]'}

<strong>4. THEORETICAL FRAMEWORK</strong>
${theory||'[Not specified]'}

<strong>5. HYPOTHESIS / ARGUMENT</strong>
${hyp||'[Not specified]'}

<strong>6. METHOD(S)</strong>
${method||'[Not specified]'}

<strong>7. CASE SELECTION</strong>
${cases||'[Not specified]'}

<strong>8. DATA / SOURCES</strong>
${data||'[Not specified]'}

<strong>9. EXPECTED CONTRIBUTION</strong>
${contrib||'[Not specified]'}

<strong>10. KEY REFERENCES</strong>
${refs||'[Not specified]'}

<strong>═══════════════════════════════════════════</strong>
