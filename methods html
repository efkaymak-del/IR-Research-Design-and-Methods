  out.classList.add('show');
  document.getElementById('bd-copy-area').style.display='block';
}

function clearBuilder(){
  ['bd-title','bd-puzzle','bd-rq','bd-epist','bd-theory','bd-hyp','bd-method','bd-cases','bd-data','bd-contrib','bd-refs'].forEach(id=>{
    const el=document.getElementById(id);
    if(el.tagName==='SELECT') el.selectedIndex=0;
    else el.value='';
  });
  document.getElementById('bd-output').classList.remove('show');
  document.getElementById('bd-copy-area').style.display='none';
}

function copyOutput(id){
  const el=document.getElementById(id);
  const text=el.innerText;
  navigator.clipboard.writeText(text).then(()=>alert('Copied to clipboard!')).catch(()=>{
    const ta=document.createElement('textarea');ta.value=text;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);alert('Copied!');
  });
}

/* Alignment Checker */
function runChecker(){
  const epist=document.getElementById('ck-epist').value;
  const theory=document.getElementById('ck-theory').value;
  const method=document.getElementById('ck-method').value;
  const n=document.getElementById('ck-n').value;
  const rq=document.getElementById('ck-rq').value.trim();
  if(!epist||!theory||!method){alert('Please fill in at least epistemology, theory, and method.');return;}

  const results=[];

  // Epistemology-Theory alignment
  const posTheories=['realism','liberalism','rational'];
  const intTheories=['constructivism','english','practice'];
  const critTheories=['marxism','feminism','postcolonial','poststructural','green'];

  if(epist==='Positivist'&&critTheories.includes(theory)){
    results.push({type:'warn',msg:'<strong>Epistemology ↔ Theory tension:</strong> You selected a positivist epistemology with a critical theory. Critical theories typically reject the positivist assumption of value-neutral, objective inquiry. This can work if you operationalise the theory in a testable way (e.g., testing Marxist hypotheses about trade dependency), but be explicit about the tension.'});
  } else if(epist==='Critical'&&posTheories.includes(theory)){
    results.push({type:'warn',msg:'<strong>Epistemology ↔ Theory tension:</strong> You selected a critical epistemology with a mainstream/positivist theory (realism, liberalism, or rational choice). These theories are typically used within positivist frameworks. Consider whether you are critiquing the theory itself, or applying a critical lens to its assumptions.'});
  } else if(epist==='Interpretivist'&&theory==='rational'){
    results.push({type:'warn',msg:'<strong>Epistemology ↔ Theory tension:</strong> Rational choice theory assumes utility-maximising agents and is typically embedded in positivist epistemology. Interpretivists generally reject this framework. If you are studying how rational-choice <em>discourses</em> are deployed, that could work — but clarify your analytical move.'});
  } else {
    results.push({type:'pass',msg:'<strong>Epistemology ↔ Theory:</strong> Your epistemological stance and theoretical tradition appear coherent.'});
  }

  // Theory-Method alignment
  const posMethods=['statistical','formal','comparison','qca','process','content','mixed_method'];
  const intMethods=['discourse','ethnography','narrative','process','content','historical'];
  const critMethods=['discourse','genealogy','feminist_method','ethnography','narrative','historical'];

  let methodOk=false;
  if(epist==='Positivist'&&posMethods.includes(method)) methodOk=true;
  if(epist==='Interpretivist'&&intMethods.includes(method)) methodOk=true;
  if(epist==='Critical'&&critMethods.includes(method)) methodOk=true;
  if(epist==='Mixed') methodOk=true;

  if(!methodOk){
    let suggestion='';
    if(epist==='Positivist') suggestion='Consider: statistical analysis, formal modelling, structured comparison, process tracing, or QCA.';
    if(epist==='Interpretivist') suggestion='Consider: discourse analysis, ethnography, interpretive process tracing, narrative analysis, or comparative historical analysis.';
    if(epist==='Critical') suggestion='Consider: critical discourse analysis, genealogy, feminist methodology, or reflexive ethnography.';
    results.push({type:'warn',msg:`<strong>Epistemology ↔ Method tension:</strong> The method you chose is not typically associated with your epistemological stance. This does not mean it's impossible, but you'll need to explicitly justify the combination. ${suggestion}`});
  } else {
    results.push({type:'pass',msg:'<strong>Epistemology ↔ Method:</strong> Your method is well-suited to your epistemological tradition.'});
  }

  // N-size check
  if(n==='large'&&['discourse','ethnography','genealogy','feminist_method','narrative'].includes(method)){
    results.push({type:'warn',msg:'<strong>N-Size ↔ Method tension:</strong> You selected a large-N design with a method that typically works with small-N or single cases (discourse analysis, ethnography, genealogy). Large-N discourse or content analysis is possible (e.g., automated text analysis), but requires a different variant of the method. Be specific.'});
  } else if(n==='1'&&['statistical','formal','qca'].includes(method)){
    results.push({type:'fail',msg:'<strong>N-Size ↔ Method mismatch:</strong> Statistical analysis, formal modelling, and QCA require multiple cases. A single case study cannot support these methods. Consider process tracing, congruence testing, or within-case analysis instead.'});
  } else if(n==='medium'&&method==='qca'){
    results.push({type:'pass',msg:'<strong>N-Size ↔ Method:</strong> Medium-N is the sweet spot for QCA. Good alignment.'});
  } else if(n){
    results.push({type:'pass',msg:'<strong>N-Size ↔ Method:</strong> Your case count and method appear compatible.'});
  }

  // RQ keyword check
  if(rq){
    const rqLow=rq.toLowerCase();
    if(epist==='Positivist'&&(rqLow.includes('how do actors understand')||rqLow.includes('what meanings')||rqLow.includes('how is')&&rqLow.includes('constructed'))){
      results.push({type:'warn',msg:'<strong>Question ↔ Epistemology note:</strong> Your research question uses interpretivist language ("understand," "meanings," "constructed") but you selected a positivist epistemology. Positivist questions typically ask about causes, effects, and conditions (e.g., "Does X lead to Y?" or "Under what conditions does X occur?"). Revisit either the question or the epistemological choice.'});
    }
    if(epist==='Interpretivist'&&(rqLow.includes('does ')&&rqLow.includes(' cause')||rqLow.includes('what is the effect'))){
      results.push({type:'warn',msg:'<strong>Question ↔ Epistemology note:</strong> Your research question uses causal language ("cause," "effect") but you selected an interpretivist epistemology. Interpretivists typically ask about meaning, constitution, and practice rather than causation. Consider rephrasing or reconsidering your stance.'});
    }
  }

  // Render results
  const container=document.getElementById('ck-results');
  container.innerHTML='<div class="section-title" style="margin-top:16px">Diagnostic Results</div>';
  results.forEach(r=>{
    const cls=r.type==='pass'?'check-pass':r.type==='warn'?'check-warn':'check-fail';
    const icon=r.type==='pass'?'✓':r.type==='warn'?'⚠':'✗';
    container.innerHTML+=`<div class="check-result ${cls}">${icon} ${r.msg}</div>`;
  });
  const allPass=results.every(r=>r.type==='pass');
  if(allPass){
    container.innerHTML+=`<div class="check-result check-pass" style="margin-top:10px"><strong>Overall:</strong> Your research design elements appear well-aligned. Proceed with confidence — but always discuss coherence with your supervisor.</div>`;
  } else {
    container.innerHTML+=`<div class="info-box" style="margin-top:10px"><strong>Next steps:</strong> Review the flagged tensions above. Alignment issues are common and fixable — the point is to be <em>explicit</em> about your choices. Discuss these with your supervisor and consult the recommended readings in the Reading Navigator tab.</div>`;
  }
}

function clearChecker(){
  ['ck-rq','ck-epist','ck-theory','ck-method','ck-n'].forEach(id=>{
    const el=document.getElementById(id);
    if(el.tagName==='SELECT') el.selectedIndex=0;
    else el.value='';
  });
  document.getElementById('ck-results').innerHTML='';
}

/* Reading Navigator */
let currentTradFilter='all';

function filterReadings(){
  renderReadings();
}

function filterByTrad(t){
  currentTradFilter=t;
  renderReadings();
}

function renderReadings(){
  const search=(document.getElementById('readSearch')?.value||'').toLowerCase();
  const container=document.getElementById('readList');
  if(!container) return;
  let filtered=READINGS;
  if(currentTradFilter!=='all'){
    filtered=filtered.filter(r=>r.tradition===currentTradFilter);
  }
  if(search){
    filtered=filtered.filter(r=>(r.title+' '+r.author+' '+r.desc+' '+r.tradition+' '+r.type).toLowerCase().includes(search));
  }
  if(filtered.length===0){
    container.innerHTML='<p style="color:#94a3b8;padding:20px;text-align:center">No readings match your search.</p>';
    return;
  }
  container.innerHTML=filtered.map(r=>{
    const tradCls=r.tradition==='Positivist'?'tag-pos':r.tradition==='Interpretivist'?'tag-int':r.tradition==='Critical'?'tag-crit':r.tradition==='Mixed'?'tag-mixed':'';
    return `<div class="reading-card">
      <h4>${r.title} (${r.year})</h4>
      <p><strong>${r.author}</strong></p>
      <p>${r.desc}</p>
      <span class="tag ${tradCls}">${r.tradition}</span> <span class="tag tag-method">${r.type}</span>
    </div>`;
  }).join('');
}

/* ========== INIT ========== */
buildApp();
setTimeout(()=>{initTradSelector();renderReadings();},50);

