/* ========== RENDER ENGINE ========== */

function buildNav(){
  const nav=document.getElementById('nav');
  TABS.forEach((t,i)=>{
    const b=document.createElement('button');
    b.textContent=t.label;
    b.id='btn-'+t.id;
    b.onclick=()=>showTab(t.id);
    nav.appendChild(b);
  });
}

function showTab(id){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('show'));
  document.querySelectorAll('nav button').forEach(b=>b.classList.remove('active'));
  const el=document.getElementById('tab-'+id);
  if(el){el.classList.add('show');}
  const btn=document.getElementById('btn-'+id);
  if(btn){btn.classList.add('active');}
}

function toggleCard(el){el.classList.toggle('open');}

function buildApp(){
  const app=document.getElementById('app');
  app.innerHTML='';
  TABS.forEach(t=>{
    const div=document.createElement('div');
    div.className='tab';
    div.id='tab-'+t.id;
    div.innerHTML=buildTabContent(t.id);
    app.appendChild(div);
  });
  buildNav();
  showTab('epistemology');
}

function buildTabContent(id){
  switch(id){
    case 'epistemology': return buildEpistemology();
    case 'alignment': return buildAlignment();
    case 'cases': return buildCases();
    case 'nsize': return buildNsize();
    case 'methods': return buildMethods();
    case 'builder': return buildBuilder();
    case 'checker': return buildChecker();
    case 'readings': return buildReadings();
    default: return '';
  }
}

/* --- TAB 1: EPISTEMOLOGICAL COMPASS --- */
function buildEpistemology(){
  let h=`<div class="section-title">The Three Traditions in IR Research</div>
  <div class="info-box">Every research design rests on epistemological foundations — assumptions about what we can know and how we can know it. Before choosing methods, understand where you stand. As Robert Cox (1981) wrote: <strong>"Theory is always for someone and for some purpose."</strong></div>`;
  TRADITIONS.forEach(t=>{
    h+=`<div class="card" onclick="toggleCard(this)">
      <h3><span class="tag ${t.tag}">${t.name}</span></h3>
      <div class="card-body">
        <p><strong>Ontology:</strong> ${t.ontology}</p>
        <p style="margin-top:8px"><strong>Epistemology:</strong> ${t.epistemology}</p>
        <p style="margin-top:8px"><strong>Goal of Research:</strong> ${t.goal}</p>
        <p style="margin-top:8px"><strong>Key Scholars:</strong> ${t.scholars}</p>
        <p style="margin-top:8px"><strong>Typical Methods:</strong> ${t.methods}</p>
        <div class="section-title" style="font-size:.95em;margin-top:14px">Canonical Works</div>
        ${t.works.map(w=>`<div class="exemplar"><strong>${w.title}</strong> — ${w.author}<br>${w.note}</div>`).join('')}
      </div>
    </div>`;
  });
  h+=`<div class="warn-box"><strong>Important:</strong> These categories are ideal types, not rigid boxes. Many scholars work across traditions — Wendt draws on both positivist and interpretivist commitments; Skocpol combines structural analysis with historical interpretation. Your job is to be <em>explicit</em> about your choices and their implications.</div>
  <div class="ref">Key overview: Kurki & Wight (2013) "International Relations and Social Science" in Dunne, Kurki & Smith, eds., <em>International Relations Theories</em>.</div>`;
  return h;
}

/* --- TAB 2: THEORY-METHOD ALIGNMENT --- */
function buildAlignment(){
  let h=`<div class="section-title">Aligning Theory, Epistemology, and Method</div>
  <div class="info-box">Coherent research design requires alignment between your theoretical framework, epistemological commitments, and methodological choices. A mismatch — for example, using positivist hypothesis-testing methods to answer an interpretivist question about meaning — undermines the entire project. This is perhaps the single most common problem in graduate research proposals.</div>
  <p style="margin:12px 0;font-size:.92em">Select a tradition to see its alignment pathway:</p>
  <div class="tradition-selector" id="tradSel"></div>
  <div id="tradDetail"></div>
  <div class="section-title" style="margin-top:20px">Quick-Reference Alignment Matrix</div>
  <div style="overflow-x:auto">
  <table class="matrix">
  <tr><th>If your question asks…</th><th>Your tradition is likely…</th><th>Your theory might be…</th><th>Your method might be…</th><th>Exemplar</th></tr>
  <tr><td>Does X cause Y? Under what conditions?</td><td><span class="tag tag-pos">Positivist</span></td><td>Realism, liberalism, rational choice, bargaining theory</td><td>Statistical analysis, formal models, structured comparison</td><td>KKV (1994); Fearon (1995)</td></tr>
  <tr><td>How do actors understand X? What meanings constitute Y?</td><td><span class="tag tag-int">Interpretivist</span></td><td>Constructivism, English School, practice theory</td><td>Discourse analysis, ethnography, interpretive process tracing</td><td>Wendt (1992); Pouliot (2010)</td></tr>
  <tr><td>Whose interests does X serve? How does Y reproduce domination?</td><td><span class="tag tag-crit">Critical</span></td><td>Marxism, feminism, postcolonialism, poststructuralism</td><td>Critical discourse analysis, genealogy, feminist methodology</td><td>Cox (1981); Enloe (1990)</td></tr>
  <tr><td>Is X necessary or sufficient for Y? What combinations produce Y?</td><td><span class="tag tag-mixed">Mixed / Set-Theoretic</span></td><td>Configurational theory, equifinality-aware frameworks</td><td>QCA, nested analysis, multi-method</td><td>Ragin (2008); Lieberman (2005)</td></tr>
  </table>
  </div>
  <div class="ref">See also: Baglione (2020), Ch. 3–4 on developing arguments and choosing approaches; Marsh & Stoker (2010), Ch. 1 on epistemology and method.</div>`;

  return h;
}

/* --- TAB 3: CASE SELECTION --- */
function buildCases(){
  let h=`<div class="section-title">Case Selection Strategies</div>
  <div class="info-box">Case selection is not arbitrary — it is one of the most consequential decisions in your research design. The logic of your case selection must match your research goal (theory testing, theory building, or causal-mechanism tracing). As George & Bennett (2005) emphasise, a poorly selected case can invalidate an otherwise strong analysis.</div>`;
  CASE_TYPES.forEach(c=>{
    h+=`<div class="card" onclick="toggleCard(this)">
      <h3>${c.name}</h3>
      <div class="card-body">
        <p><strong>Also known as:</strong> ${c.aka}</p>
        <p style="margin-top:8px"><strong>Logic:</strong> ${c.logic}</p>
        <p style="margin-top:8px"><strong>IR Example:</strong> ${c.example}</p>
        <p style="margin-top:8px"><strong>When to Use:</strong> ${c.when}</p>
        <div class="ref">${c.ref}</div>
      </div>
    </div>`;
  });
  h+=`<div class="section-title">Case Selection Decision Flowchart</div>
  <div class="info-box">
  <strong>Ask yourself:</strong><br><br>
  1. Is my goal to <strong>test</strong> an existing theory? → Consider a <strong>crucial case</strong> (most-likely or least-likely) or <strong>MSSD</strong>.<br><br>
  2. Is my goal to <strong>build</strong> new theory? → Consider a <strong>deviant case</strong>, an <strong>exploratory case</strong>, or <strong>MDSD</strong>.<br><br>
  3. Is my goal to trace <strong>causal mechanisms</strong>? → Consider a <strong>pathway case</strong> with process tracing.<br><br>
  4. Do I want to show an outcome is <strong>robust across contexts</strong>? → Consider <strong>MDSD</strong> or <strong>typological</strong> selection.<br><br>
  5. Am I working with <strong>medium-N</strong> (10–50)? → Consider <strong>QCA-driven case selection</strong>.
  </div>
  <div class="ref">Essential reading: Seawright & Gerring (2008) "Case Selection Techniques in Case Study Research" in <em>Political Research Quarterly</em>; Gerring (2007) <em>Case Study Research</em>.</div>`;
  return h;
}

/* --- TAB 4: N-SIZE --- */
function buildNsize(){
  let h=`<div class="section-title">The N-Size Decision: How Many Cases?</div>
  <div class="info-box">The number of cases you study fundamentally shapes what kinds of claims you can make. King, Keohane & Verba (1994) argue that the logic of inference is the same regardless of N — but many scholars disagree. The key insight: choose N based on your research question and epistemology, not convention.</div>`;
  NSIZE.forEach(n=>{
    h+=`<div class="card" onclick="toggleCard(this)">
      <h3>${n.type}</h3>
      <div class="card-body">
        <p><strong>Typical N:</strong> ${n.n}</p>
        <p style="margin-top:8px"><strong>Strengths:</strong> ${n.strengths}</p>
        <p style="margin-top:8px"><strong>Limitations:</strong> ${n.limits}</p>
        <p style="margin-top:8px"><strong>Methods:</strong> ${n.methods}</p>
        <p style="margin-top:8px"><strong>Key References:</strong> ${n.key_refs}</p>
        <div class="exemplar"><strong>IR Example:</strong> ${n.ir_example}</div>
      </div>
    </div>`;
  });
  h+=`<div class="section-title">The KKV Debate</div>
  <div class="info-box">King, Keohane & Verba's <em>Designing Social Inquiry</em> (1994) argued that qualitative research should aspire to the same inferential logic as quantitative research — maximising observations, avoiding selection bias, and testing hypotheses. This sparked an enormous debate. Critics (Brady & Collier 2004; Ragin 2008; Schwartz-Shea & Yanow 2012) argued that KKV misunderstands the distinct logics of qualitative, interpretive, and set-theoretic inquiry. Your task is not to "pick a side" but to understand the stakes of this debate for your own design choices.</div>
  <div class="ref">Brady & Collier, eds. (2004) <em>Rethinking Social Inquiry</em>; Goertz & Mahoney (2012) <em>A Tale of Two Cultures</em>.</div>`;
  return h;
}

/* --- TAB 5: METHODS LIBRARY --- */
function buildMethods(){
  let h=`<div class="section-title">Methods for IR Research</div>
  <div class="info-box">Methods are the tools of inquiry — but they are not neutral. Each method carries epistemological assumptions and is suited to particular kinds of questions. This library describes major methods used in IR, with guidance on when to use them and exemplary studies that demonstrate each one.</div>`;
  METHODS_LIB.forEach(m=>{
    h+=`<div class="card" onclick="toggleCard(this)">
      <h3>${m.name} <span style="font-size:.75em;font-weight:400;color:#64748b">${m.tradition}</span></h3>
      <div class="card-body">
        <p>${m.desc}</p>
        <p style="margin-top:8px"><strong>When to use:</strong> ${m.when}</p>
        <p style="margin-top:8px"><strong>Variants:</strong> ${m.variants}</p>
        <div class="exemplar" style="margin-top:10px">
          <strong>Exemplary IR Study:</strong> ${m.exemplar.title} — ${m.exemplar.author}<br>${m.exemplar.note}
        </div>
        <p style="margin-top:8px"><strong>Key Readings:</strong> ${m.readings}</p>
        <div style="margin-top:6px">${m.tags.map(t=>`<span class="tag ${t}">${t.replace('tag-','').replace('pos','Positivist').replace('int','Interpretivist').replace('crit','Critical').replace('mixed','Mixed')}</span>`).join(' ')}</div>
      </div>
    </div>`;
  });
  return h;
}

/* --- TAB 6: RESEARCH DESIGN BUILDER --- */
